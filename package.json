{
  "name": "zstd-napi",
  "version": "0.0.12",
  "description": "Zstandard (zstd) compression library bindings with Node-API",
  "keywords": [
    "binding",
    "compression",
    "native",
    "zstandard",
    "zstd",
    "Node-API",
    "N-API"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/drakedevel/zstd-napi.git"
  },
  "license": "Apache-2.0",
  "author": "Andrew Drake <adrake@adrake.org>",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "NOTICE",
    "binding.d.ts",
    "binding.gyp",
    "binding.js",
    "build_flags.gypi",
    "deps",
    "dist",
    "src"
  ],
  "binary": {
    "napi_versions": [
      8
    ]
  },
  "scripts": {
    "build": "node-gyp configure && node-gyp build",
    "ci-ignore-scripts": "npm ci --ignore-scripts",
    "clang-format": "clang-format -i src/*",
    "install": "prebuild-install -r napi || node-gyp rebuild",
    "lint": "eslint .",
    "prepare": "tsc -p tsconfig.emit.json",
    "prettier": "prettier -l --write .",
    "submodule-update": "git submodule update --init",
    "test": "jest",
    "test-coverage": "jest --coverage --coverageReporters=json",
    "typedoc": "typedoc"
  },
  "dependencies": {
    "@types/node": "*",
    "node-addon-api": "^7.0.0",
    "prebuild-install": "^7.1.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@fast-check/jest": "2.2.0",
    "@jest/globals": "30.4.1",
    "@tsconfig/node20": "20.1.9",
    "@tsconfig/strictest": "2.0.8",
    "@types/eslint-config-prettier": "6.11.3",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-tsdoc": "0.5.2",
    "expect-type": "1.3.0",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "node-gyp": "12.3.0",
    "prettier": "3.8.3",
    "ts-jest": "29.4.9",
    "typedoc": "0.28.19",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.3"
  },
  "engines": {
    "node": "^12.22.0 || ^14.17.0 || ^15.12.0 || >=16"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm"
    }
  }
}
